// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://sakiyuka@localhost:5432/mcn_db"
}

// --------------------------------------
// 账号管理 (PRD 4.1 & 4.2)
// --------------------------------------

model Account {
  id          String   @id @default(uuid())
  platform    String   // twitter, bilibili, etc.
  uid         String   // 平台内部ID (如 Twitter ID)
  name        String
  avatar      String?
  cookies     String?  // 敏感信息，存储 Cookie JSON
  status      String   @default("active") // active, suspended, invalid
  
  // 关联代理IP (PRD 4.2: 独立IP绑定)
  proxyId     String?  @unique
  proxy       ProxyIp? @relation(fields: [proxyId], references: [id])

  // 任务关联
  tasks       Task[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProxyIp {
  id          String   @id @default(uuid())
  ip          String
  port        Int
  username    String?
  password    String?
  protocol    String   @default("http") // http, socks5
  region      String?  // us, jp, uk
  
  // 类型区分: publish(发布用-独享), monitor(监控用-共享池)
  type        String   @default("publish") 
  status      String   @default("active") // active, dead, slow
  
  account     Account? // 反向关联

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --------------------------------------
// 素材管理 (PRD 2.1)
// --------------------------------------

model Material {
  id          String   @id @default(uuid())
  platform    String   // bilibili, douyin, xiaohongshu
  sourceUrl   String   // 原始链接
  
  title       String
  description String?
  tags        String?  // 简单存储 JSON array string
  
  coverUrl    String?
  videoPath   String?  // 本地存储路径 (相对)
  audioPath   String?
  
  // 原始元数据备份 (JSON)
  rawJson     String?
  
  status      String   @default("pending") // pending(未处理), downloaded, published, archived
  
  authorUid   String?
  authorName  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --------------------------------------
// 任务系统 (PRD 3.3)
// --------------------------------------

model Task {
  id          String   @id @default(uuid())
  type        String   // collect, publish
  status      String   @default("pending") // pending, running, success, failed, paused
  
  // 任务配置载荷 (JSON)
  config      String? 
  
  // 关联账号 (发布任务)
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id])
  
  logs        TaskLog[]
  
  errorMessage String?
  
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskLog {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  level     String   @default("info")
  message   String
  timestamp DateTime @default(now())
}
